# Project PLAN: megafish-duplex — low-latency half-duplex Chinese voice (Qwen3-Omni / Megatron),
# as the path to full listen-while-speak duplex. Ordered DECISIONS, each tagged with the
# transferable PRINCIPLE that governs it. Draft with /trainlint:plan; walk with /trainlint:quiz.
# fields: id | phase | decision | choice | principle | why | status(open|decided|verified) | match(regex)
{"id": "data-source", "phase": "data", "decision": "Where do training workers read the packed conversation dataset from?", "choice": "immutable object-store packed datasets (minio full-flash); never a mutable/JFS mount", "principle": "verify-data-before-blaming-algorithm", "why": "a mount that corrupts under concurrent reads -> garbage wav -> NaN -> errors that look like a model bug", "status": "decided", "match": "/jfs/|/nas/|data\\.path|PackedDataset|object.?store|minio|storage"}
{"id": "dialogue-data", "phase": "data", "decision": "Where do voice-in/voice-out conversational turns with real turn boundaries come from?", "choice": "derive (user-turn, assistant-turn) pairs from real multi-speaker recordings (e.g. ximalaya), preserving natural turn timing; NOT single-speaker TTS concatenation", "principle": "data-must-contain-the-behavior-you-want", "why": "the model can only learn turn-taking from data that HAS real turns and gaps; single-speaker TTS has none, so it can never learn when to start", "status": "open", "match": "ximalaya|dialogue|conversation|turn|multi.?speaker|s2_mixture|source_data"}
{"id": "codec-contract", "phase": "preproc", "decision": "What frozen codec/encoder geometry must all audio I/O match?", "choice": "48kHz->25Hz frame grid, 10 codebooks (semantic 4096 + 9 acoustic 1024); understanding mel = WhisperLogMel 16kHz/n_fft400/hop160/n_mels128 magnitude", "principle": "frozen-component-contract", "why": "the codec/encoder is a black box trained at fixed settings; any mismatched value (sample rate, codebook count, power) silently produces OOD codes", "status": "verified", "match": "modded_dac|sample_rate|n_codebooks|codebook_vocab|MelSpectrogram|WhisperLogMel|\\bpower\\b|25hz|48000", "pillar": true}
{"id": "gap-fill", "phase": "preproc", "decision": "How do we fill the silence between turns when assembling dialogue?", "choice": "real floor noise (~-50dB), never np.zeros", "principle": "frozen-component-contract", "why": "the frozen codec maps pure zeros to a fixed OOD code, not natural quiet; that code would dominate the inter-turn targets", "status": "decided", "match": "np\\.zeros|silence|\\bpad\\b|gap|fill|floor.?noise"}
{"id": "ckpt-init", "phase": "ckpt", "decision": "What do we initialize the duplex run from?", "choice": "the production S2/Omni voice checkpoint (already speaks+listens); NOT text base, NOT a half-baked experimental duplex ckpt", "principle": "init-from-the-capable-checkpoint-when-adding-behavior", "why": "turn-taking is a behavior added on top of intact speaking; text base would re-learn audio from scratch (wasteful), a rotted experimental ckpt would carry garbage forward", "status": "decided", "match": "ckpt|checkpoint|resume|pretrained|from.?base|init.?from|load.?weights|s2", "not_this": "initializing fresh-from-text-base (throwing away the trained audio ability) OR resuming a half-baked experimental duplex ckpt that carries rot", "not_re": "(from|init|load|--).{0,16}(text.?base|scratch|qwen3.?base)|(resume|continue|继续|接着).{0,20}(experimental|broken|半成品|duplex.?exp)"}
{"id": "ar-shift", "phase": "model", "decision": "Is the autoregressive off-by-one preserved after our edits?", "choice": "keep tokens[:-1] vs labels[1:] exactly as base (content_sequence.py:441)", "principle": "train-infer-parity", "why": "drop the shift and the model predicts token t from token t -> learns to echo its input", "status": "verified", "match": "cross_entropy|labels|shift|\\bloss\\b|content_sequence"}
{"id": "streaming-encoder", "phase": "model", "decision": "Causal or bidirectional encoder for the user-audio input?", "choice": "causal streaming encoder (attention_window_size [255,0], no lookahead, RoPE, no center); NOT bidirectional", "principle": "info-set-must-match-deployment-causality", "why": "a bidirectional encoder attends the whole clip so 'now' already encodes the future; streaming has only up-to-now -> codes go OOD. megafish already built the causal path at ~70ms", "status": "decided", "match": "encoder|bidirectional|streaming|attention_window|causal|lookahead|swa", "pillar": true, "not_this": "using the bidirectional full-attention encoder because it scores better offline", "not_re": "bidirectional|full.?attention|attention_window_size:\\s*\\[-1|center\\s*=\\s*True"}
{"id": "turn-layout", "phase": "model", "decision": "How is a voice-in/voice-out turn laid out in the sequence?", "choice": "user-audio turn (encoder tokens) -> assistant text+voice turn, role/im_start-delimited, one 1-D causal stream", "principle": "clean-role-delimited-turn-layout", "why": "the model must know whose audio is whose and when its own turn starts; reuse the existing IM_START+role+modality turn machinery (conversation.py) rather than inventing a new axis", "status": "decided", "match": "layout|turn|im_start|role|conversation|modality|interleave", "pillar": true}
{"id": "role-separation", "phase": "model", "decision": "How does the model tell user audio from its own?", "choice": "role/im_start + speaker tokens with comparable embedding magnitude; not a tiny additive role constant", "principle": "small-additive-signal-gets-swamped", "why": "a role signal that trains to ~1e-5 against a code-embedding norm ~0.6 gets swamped -> the streams cross-talk", "status": "decided", "match": "role|speaker|user.?asst|role.?emb|additive|im_start"}
{"id": "endpoint-token", "phase": "loss", "decision": "How does the model learn WHEN the user finished and it should start?", "choice": "an explicit turn-boundary (end-of-user / start-of-assistant) token the model predicts; weight its loss so it is actually learned", "principle": "majority-class-loss-weight-sets-behavior", "why": "the boundary is rare against the many speech/silence frames; under-weighted -> the model never learns to start on time -> bad latency or talking over the user. NOT a decoding-temperature problem", "status": "open", "load_bearing": true, "match": "endpoint|turn.?boundary|start|stop|eos|loss.?weight|abstain|empty", "pillar": true}
{"id": "vq-loss-weights", "phase": "loss", "decision": "What weights on text vs vq vs codebooks?", "choice": "start from megafish defaults (codebook_loss_weight 0.5, base_vq_weight 0.5); raise the empty/boundary weight if the model won't wait/start", "principle": "majority-class-loss-weight-sets-behavior", "why": "dominant targets need enough weight to shape behavior; defaults are a starting point, not gospel", "status": "decided", "match": "codebook_loss_weight|base_vq_weight|loss.?weight|vq.?weight"}
{"id": "freeze-regime", "phase": "train", "decision": "What is frozen vs trained?", "choice": "freeze the audio encoder, train backbone + codebook-MTP decoder (decoder_lr_factor 1.66) as in S2", "principle": "dont-retrain-a-working-frozen-piece", "why": "the encoder already works causal; retraining it under a new contract regressed quality (STREAMING_AUDIO_ENCODER.md). Add the behavior in the backbone/decoder", "status": "decided", "match": "freeze|nofreeze|freeze_audio|decoder_lr|trainable"}
{"id": "lr-regime", "phase": "train", "decision": "What LR/optimizer regime?", "choice": "megafish regime: dist_muon, lr ~6e-4 WSD, warmup 1k; don't copy an unrelated stage's LR", "principle": "hparams-dont-transfer-across-regimes", "why": "an LR that fits one regime steps too big/small in another -> diverge or overfit", "status": "decided", "match": "\\blr\\b|learning_rate|muon|wsd|warmup|optimizer"}
{"id": "eff-batch", "phase": "train", "decision": "How do we reach a large effective batch without OOM?", "choice": "grad-accum under Megatron TP=8, not per-device stacking", "principle": "backward-is-the-memory-bottleneck", "why": "backward peak (grads+activations) scales with per_device -> OOM; grad-accum sums gradients without raising the peak", "status": "verified", "match": "micro_batch|grad.?accum|global_batch|tensor_model_parallel|gbs|tp="}
{"id": "train-enough", "phase": "train", "decision": "Have we trained long enough before judging a result?", "choice": "rule out under-training before blaming the design", "principle": "rule-out-the-trunk-before-blaming-a-branch", "why": "robotic/looping/won't-start output is often under-training, not a design bug", "status": "decided", "match": "epoch|under.?train|trained.?enough|steps|iters"}
{"id": "eval-protocol", "phase": "eval", "decision": "How do we measure it learned to converse?", "choice": "free-running voice-in -> generate -> ASR -> CER; NOT teacher-forced top-1", "principle": "free-running-not-teacher-forced-is-the-test", "why": "teacher-forcing feeds the GT past so continuing one frame is easy; free-running compounds errors and exposes collapse", "status": "decided", "match": "teacher.?forc|tf_top1|top.?1|free.?run|自由生成|\\bcer\\b|\\beval\\b|generate"}
{"id": "endpoint-latency-eval", "phase": "eval", "decision": "How do we measure turn-taking quality under deployment conditions?", "choice": "measure response latency + early/false-endpoint rate with NO crutch (no forced text, no GT user-turn-end)", "principle": "eval-conditions-must-equal-deployment", "why": "a crutch that hands the model the user-turn-end secretly solves the hardest sub-task; deployment has none, so the number is a lie", "status": "open", "match": "latency|endpoint|turn.?tak|crutch|onset|forced.?text|false.?start"}
{"id": "streaming-serve", "phase": "deploy", "decision": "How does serving achieve low latency and listen-while-idle?", "choice": "incremental audio out + the causal encoder running as audio arrives + endpoint detection; today's serve is non-streaming with no VAD", "principle": "info-set-must-match-deployment-causality", "why": "low latency needs first-audio-fast and the encoder consuming audio as it streams, not after a whole turn is buffered", "status": "open", "match": "serve|rollout|stream|vad|endpoint|latency|incremental|session"}
