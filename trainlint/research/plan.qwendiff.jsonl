# Project PLAN for qwendiff (Qwen3-base -> block-diffusion LM) — ordered DECISIONS, each
# tagged with the transferable PRINCIPLE that governs it. fields: id | phase | decision |
# choice | principle | why | status(open|decided|verified) | match(regex)
{"id": "checkpoint-source", "phase": "foundation", "decision": "Which checkpoint do we init the diffusion LM from? (Qwen3.6 ships ONLY as 27B+ instruct/multimodal — no base, nothing small.)", "choice": "Qwen3-{4B,8B}-Base (prior-family small TEXT base) to develop the recipe; Qwen3.6 is the north-star to scale to once it works. Contract from Qwen3-4B-Base config.json: hidden 2560, 36 layers, 32 heads/8 KV (GQA), vocab 151936, head_dim 128, rope_theta 1e6, tie_word_embeddings=true, no sliding window.", "principle": "verify-init-checkpoint-loads", "why": "Qwen3.6 (Apr 2026, Apache-2.0) exists only as 27B-dense and 35B-A3B, both POST-TRAINED and VISION-LANGUAGE — no -Base, nothing <27B. Diffusion adaptation wants a clean small text BASE; Qwen3-4B/8B-Base provide it and iterate fast. tie_word_embeddings=true means a [MASK] add resizes embed+lm_head together.", "status": "decided", "match": "from_pretrained|load.*ckpt|checkpoint|\\.safetensors|model.?id|Qwen3-?4B|Qwen3-?8B|Base|huggingface|snapshot_download"}
{"id": "codebase-home", "phase": "foundation", "decision": "Where does the training code live and what does it reuse?", "choice": "fresh repo at /mnt/minio/shiyil/qwen3 (build new; HF Qwen3 modeling as the arch reference rather than megafish's MoE-TTS DiT)", "principle": "reuse-verified-reference", "why": "user chose a fresh repo; the empty Qwen3.6 clone is docs-only, so the arch reference is HF transformers Qwen3 modeling (causal decoder) which we patch, NOT megafish pretrain_dit.py (audio-latent DiT-TTS, a different problem).", "status": "decided", "match": "/mnt/minio/shiyil/qwen3|new repo|trainer|train\\.py|pretrain"}
{"id": "attention-bidirectional", "phase": "architecture", "decision": "What attention pattern — full bidirectional, or BLOCK-causal (BD3-LM, block_size=32)?", "choice": "block-causal hybrid: causal ACROSS 32-token blocks, full bidirectional WITHIN each block. Not pure-causal (=AR, defeats parallel denoising), not pure-bidirectional (loses KV-cache + harder AR-init shift).", "principle": "diffusion-needs-bidirectional-attention", "why": "a masked slot must read clean tokens to its RIGHT to be filled in; causal hides them -> collapses to AR. Block-causal keeps that intra-block bidirectionality while staying close to Qwen3's causal init (gentler adaptation), preserving KV-cache across finished blocks and enabling variable-length semi-AR generation.", "status": "decided", "pillar": true, "match": "causal|is_causal|attn.?mask|attention_mask|bidirectional|block.?causal|block.?diag|sdpa|flash.?attn|triangular"}
{"id": "predict-in-place", "phase": "architecture", "decision": "Is the training target the SAME position (in-place) or the NEXT token (AR shift)?", "choice": "in-place: loss compares logits[i] to labels[i] at masked positions — NO next-token shift", "principle": "in-place-not-shifted", "why": "diffusion predicts the clean token AT each masked slot, not the next one. The AR off-by-one rule (logits[:,:-1] vs labels[:,1:]) is REVERSED here; echoing the AR shift silently corrupts the objective.", "status": "decided", "not_this": "applying the AR next-token shift (logits[:,:-1] vs labels[:,1:]) to the diffusion loss", "not_re": "logits\\[.*:-1\\]|labels\\[.*1:\\]|shift_logits|shift_labels|next.?token", "match": "loss|cross_entropy|labels|target|in.?place|shift"}
{"id": "diffusion-formulation", "phase": "objective", "decision": "Which diffusion formulation — discrete masked/absorbing, or continuous embedding diffusion?", "choice": "BLOCK discrete masked/absorbing diffusion (BD3-LM): within each 32-token block, forward process replaces tokens with a [MASK] absorbing state; blocks decoded left-to-right (semi-AR).", "principle": "masked-absorbing-diffusion", "why": "masked diffusion reuses the LM vocab + cross-entropy and adapts cleanly from an AR checkpoint (LLaDA, Dream). The BLOCK variant (BD3-LM) interpolates AR<->diffusion: likelihood closer to AR, KV-cache + arbitrary length, while still denoising 32 tokens in parallel. Continuous/Gaussian embedding diffusion would discard the AR head.", "status": "decided", "match": "absorbing|mask.*token|d3pm|mdlm|llada|bd3|block.?diff|forward.?process|q_sample|noise"}
{"id": "loss-weighting", "phase": "objective", "decision": "How is the per-step masked-CE loss weighted across mask-rate t?", "choice": "loss = (1/t) * mean CE on masked positions (LLaDA/MDLM continuous-time ELBO weight)", "principle": "weight-loss-by-mask-rate", "why": "the diffusion ELBO reduces to E_t[ (1/t) * mean CE on masked tokens ] (LLaDA/MDLM continuous-time weight). Without 1/t the low-mask regime (few tokens masked = the decisive end of denoising) gets drowned by the high-mask regime; samples degrade.", "status": "decided", "pillar": true, "match": "weight|1/t|loss.*scale|elbo|reweight|mask.?ratio|alpha_t"}
{"id": "noise-schedule", "phase": "objective", "decision": "How is the mask-rate sampled/scheduled during the forward process?", "choice": "", "principle": "noise-schedule-choice", "why": "training samples t (fraction masked) per example; uniform t in [0,1] (LLaDA) vs cosine/clipped schedules change which corruption levels the model is trained on and interacts with the loss weight.", "status": "open", "match": "schedule|cosine|linear|uniform|t.?sample|mask.?prob|alpha"}
{"id": "mask-token", "phase": "architecture", "decision": "How is the [MASK] absorbing token represented in the Qwen3 vocab?", "choice": "", "principle": "frozen-component-contract", "why": "Qwen3's tokenizer has no diffusion [MASK]; we either repurpose a reserved special-token id or extend the embedding+LM-head by one row. tie_word_embeddings=true means resize covers both. A wrong/colliding id maps mask to a real token and poisons every masked position.", "status": "open", "match": "mask.?token|mask_id|special.?token|vocab|resize.*embed|added_tokens|reserved"}
{"id": "ar-weight-adaptation", "phase": "init", "decision": "How do we adapt the Qwen3 base AR weights so diffusion training preserves the base model's knowledge?", "choice": "Anneal, don't shock: ramp intra-block attention causal->bidirectional over a warmup (DiffuLLaMA-style mask annealing), low continued-pretrain LR (~1e-5..5e-5 + warmup, NOT 3e-4); block-causal already keeps init close. VALIDATE via base-init vs random-init ablation (same recipe/steps): curves must SEPARATE, else AR knowledge didn't transfer. Failure mode is SILENT catastrophic forgetting; loss-dropping alone is NOT a success criterion.", "principle": "anneal-not-shock", "why": "switching causal->full attention is a hard distribution shift; DiffuLLaMA anneals the attention mask from causal to full over early steps, Dream uses a hard switch + token-shift init. Init-from-weights (NOT from scratch) is the whole point. Cheapest invalidating test: base-init vs random-init ablation, same recipe/steps — base must beat random AND emit a coherent short denoised sample, else the AR init didn't transfer.", "status": "decided", "pillar": true, "load_bearing": true, "not_this": "training the diffusion LM from scratch / discarding the Qwen3.6 pretrained weights", "not_re": "from.?scratch|random.?init|train.*scratch|reinit|fresh.?weights|kaiming|xavier", "match": "init|anneal|warmup.*mask|adapt|continued.?pretrain|load.*weight|knowledge"}
{"id": "block-size", "phase": "architecture", "decision": "What block size for block-diffusion, and how do blocks tile the sequence?", "choice": "block_size=32 (user choice): sequence split into contiguous 32-token blocks; intra-block bidirectional + cross-block causal. Smaller=more AR-like (lower latency/quality floor), larger=more parallel denoising per step.", "principle": "block-size-tradeoff", "why": "block size is the AR<->diffusion knob: B=1 is pure AR, B=L is full diffusion. 32 balances parallel denoising against KV-cache reuse and a likelihood close to AR; it also sets the attention mask structure and the per-block denoising-step budget at inference.", "status": "decided", "match": "block.?size|block_size|=\\s*32|chunk|tile|cu_seqlens|block.?len"}
{"id": "pretrain-corpus", "phase": "data", "decision": "What text corpus do we continue-pretrain on?", "choice": "", "principle": "verify-data-before-blaming-algorithm", "why": "diffusion adaptation needs a broad, clean text corpus; domain/quality/dedup of this data sets the ceiling and a leaked or skewed mix will look like a method failure.", "status": "open", "match": "corpus|dataset|data.?dir|\\.jsonl|tokeniz|pack|domain|dedup"}
{"id": "attention-packing", "phase": "data", "decision": "How are samples packed into a sequence given block-causal (non-fully-causal) attention?", "choice": "", "principle": "no-cross-sample-leak", "why": "with bidirectional-within-block attention, naive packing lets tokens attend ACROSS document boundaries (leakage that causal packing avoided); need block-diagonal/document attention masks or one-doc-per-sequence.", "status": "open", "match": "pack|block.?diag|document.?mask|seq.?len|cu_seqlens|boundary|attn.?mask"}
{"id": "lr-schedule", "phase": "training", "decision": "What LR and schedule for continued-pretrain from a converged AR checkpoint?", "choice": "", "principle": "low-lr-for-continued-pretrain", "why": "init is already-converged Qwen3 base weights; a from-scratch LR (e.g. 3e-4) would shock them. Continued pretraining wants a low LR (~1e-5..1e-4) with warmup; the schedule must be written into config, not left to a launcher default.", "status": "open", "match": "\\blr\\b|learning.?rate|warmup|cosine|scheduler|max_steps|1e-?[45]"}
{"id": "parallelism-batch", "phase": "training", "decision": "What parallelism, batch size, and sequence length?", "choice": "", "principle": "batch-and-parallel-fit", "why": "fresh repo needs FSDP/DDP choice, global batch, and seq len chosen for the model size from checkpoint-source; block diffusion's intra-block full attention has no KV-cache during training, so memory/throughput differ from AR.", "status": "open", "match": "fsdp|ddp|deepspeed|batch|micro.?batch|grad.?accum|seq.?len|tp|pp|zero"}
{"id": "eval-protocol", "phase": "eval", "decision": "How do we measure progress toward the done-bar (coherent text approaching the AR base)?", "choice": "", "principle": "eval-matches-done-bar", "why": "diffusion LM quality is measured by generative perplexity under an external AR judge + a few zero-shot benchmarks + qualitative coherence; training CE on masked tokens alone does NOT track sample quality.", "status": "open", "match": "eval|perplexity|gen.?ppl|mmlu|benchmark|zero.?shot|coheren|judge"}
{"id": "sampling-decode", "phase": "inference", "decision": "How do we decode — semi-AR block order, denoising steps per block, remasking, KV-cache?", "choice": "", "principle": "iterative-unmask-decoding", "why": "BD3-LM decodes block-by-block left-to-right: each 32-token block starts all-[MASK], gets iteratively unmasked over K steps (LLaDA low-confidence remasking) while attending to cached finished blocks; EOS-in-block ends generation (free variable length). Open: steps-per-block K, remasking rule, stopping.", "status": "open", "match": "sample|decode|nfe|steps|remask|confidence|denoise|block|length|infer|kv.?cache"}
